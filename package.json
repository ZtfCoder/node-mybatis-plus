{
  "name": "node-mybatis-plus",
  "version": "0.1.1",
  "description": "MyBatis-Plus style ORM for Node.js with lambda query, dynamic SQL and multi-database support",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "prepublishOnly": "npm run build",
    "docs:dev": "cd docs-site && npx vitepress dev",
    "docs:build": "cd docs-site && npx vitepress build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZtfCoder/node-mybatis-plus.git"
  },
  "homepage": "https://ztfcoder.github.io/node-mybatis-plus/",
  "bugs": {
    "url": "https://github.com/ZtfCoder/node-mybatis-plus/issues"
  },
  "keywords": [
    "orm",
    "mybatis",
    "mybatis-plus",
    "lambda-query",
    "typescript"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "better-sqlite3": "^12.8.0",
    "mysql2": "^3.20.0",
    "pg": "^8.20.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "better-sqlite3": "^11.0.0",
    "mysql2": "^3.0.0",
    "pg": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "mysql2": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    }
  }
}
